<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Partner Dashboard</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">

<style>

body{
font-family:Inter,sans-serif;
background:#0f172a;
color:#f8fafc;
padding:30px;
}

.wrapper{
max-width:1400px;
margin:auto;
}

h1{
margin-bottom:5px;
}

#lastUpdate{
opacity:.7;
font-size:13px;
margin-bottom:20px;
}

.stats{
display:flex;
gap:20px;
margin-bottom:25px;
}

.stat-card{
background:#1e293b;
padding:18px;
border-radius:12px;
flex:1;
}

.stat-number{
font-size:28px;
font-weight:700;
margin-top:5px;
}

.filters{
display:flex;
gap:15px;
margin-bottom:20px;
}

.search,select{
padding:10px 14px;
border-radius:8px;
border:none;
font-size:14px;
}

.topbar{
display:flex;
gap:10px;
margin-bottom:20px;
}

.copy-btn{
padding:10px 16px;
border:none;
border-radius:8px;
background:#38bdf8;
color:white;
font-weight:600;
cursor:pointer;
}

.copy-btn:hover{
background:#0ea5e9;
}

table{
width:100%;
border-collapse:collapse;
background:#1e293b;
border-radius:12px;
overflow:hidden;
margin-bottom:40px;
}

thead{
background:#334155;
}

thead th{
position:sticky;
top:0;
z-index:2;
}

th{
padding:14px;
text-align:left;
font-size:13px;
font-weight:600;
}

td{
padding:14px;
font-size:13px;
border-top:1px solid rgba(255,255,255,.05);
white-space:nowrap;
}

td.brands{
white-space:normal;
max-width:350px;
line-height:1.4;
}

tbody tr:hover{
background:#475569;
}

.row-contract{
background:#facc15;
color:#000;
}

.row-discussion{
background:#1f4e79;
}

.row-inactive{
background:#7f2d2d;
}

.row-other{
background:#1e293b;
}

.company{
font-weight:600;
}

</style>

</head>

<body>

<div class="wrapper">

<h1>Partner Dashboard</h1>
<div id="lastUpdate"></div>

<div class="stats">

<div class="stat-card">
Export Partners
<div class="stat-number" id="exportCount">0</div>
</div>

<div class="stat-card">
Contracts
<div class="stat-number" id="contractCount">0</div>
</div>

<div class="stat-card">
Discussion
<div class="stat-number" id="discussionCount">0</div>
</div>

<div class="stat-card">
Inactive
<div class="stat-number" id="inactiveCount">0</div>
</div>

</div>

<div class="filters">

<input
type="text"
class="search"
placeholder="Search company, brand, contact..."
onkeyup="render()"
id="searchInput"
/>

<select id="statusFilter" onchange="render()">
<option value="">All status</option>
<option value="contract">Contract</option>
<option value="discussion">Discussion</option>
<option value="inactive">Inactive</option>
</select>

</div>

<div class="topbar">
<button onclick="copyTable('export')" class="copy-btn">Copy Export Table</button>
<button onclick="copyTable('import')" class="copy-btn">Copy Import Table</button>
</div>

<h2>Export Partners</h2>

<table id="exportTable">

<thead>
<tr>
<th>Status</th>
<th>Company</th>
<th>Contact</th>
<th>Country</th>
<th>Phone</th>
<th>Brands</th>
<th>Status Date</th>
</tr>
</thead>

<tbody id="exportBody"></tbody>

</table>

<h2>Import Partners</h2>

<table id="importTable">

<thead>
<tr>
<th>Status</th>
<th>Company</th>
<th>Contact</th>
<th>Country</th>
<th>Phone</th>
<th>Brands</th>
<th>Status Date</th>
</tr>
</thead>

<tbody id="importBody"></tbody>

</table>

</div>

<script>

const API_URL="https://script.google.com/macros/s/AKfycbyJIJ718HHofwJhyyfxJ_qcq1-GcOCNxscZ_sCMsDAThG1vOmTRxWzfs6Vogz30h6nj/exec";

let allData=[];

function load(){

const script=document.createElement("script");
script.src=API_URL+"?callback=handleData&_="+Date.now();
document.body.appendChild(script);

}

function handleData(data){

allData=data;

document.getElementById("lastUpdate").innerText =
"Last update: "+new Date().toLocaleTimeString();

render();

}

function normalize(r){

return{
company:r.Company||"",
contact:r.Contact||"",
country:r.Country||"",
phone:r.Phone||"",
brands:(r.Brands||"").split(",").join("<br>"),
type:(r.Type||""),
status:r["Státusz"]||"",
statusDate:r["Státusz változás"]||""
};

}

function formatDate(d){

if(!d) return "";

const date=new Date(d);

if(isNaN(date)) return d;

return date.toISOString().split("T")[0];

}

function getStatusClass(status){

const s=status.toLowerCase();

if(s.includes("szerződés")) return "contract";
if(s.includes("termék")) return "discussion";
if(s.includes("nem aktív") || s.includes("inactive")) return "inactive";
if(s.includes("aktív") || s.includes("active")) return "contract";

return "other";

}

function buyerPriority(status){

const s=status.toLowerCase();

if(s.includes("szerződés")) return 1;
if(s.includes("termék")) return 2;
if(s.includes("drágák")) return 3;
if(s.includes("nem aktív")) return 4;

return 5;

}

function sellerPriority(status){

const s=status.toLowerCase();

if(s.includes("aktív") && !s.includes("nem")) return 1;
if(s.includes("nem aktív")) return 2;

return 3;

}

function matchSearch(p,term){

const text = (
p.company +
p.contact +
p.country +
p.phone +
p.brands +
p.status
).toLowerCase();

return text.includes(term);

}

function render(){

const search=document.getElementById("searchInput").value.toLowerCase();
const statusFilter=document.getElementById("statusFilter").value;

let rows=allData.map(normalize);

if(search){
rows = rows.filter(p=>matchSearch(p,search));
}

if(statusFilter){
rows = rows.filter(p=>getStatusClass(p.status)==statusFilter);
}

const buyers=rows.filter(r=>r.type.toLowerCase().includes("buyer"));
const sellers=rows.filter(r=>r.type.toLowerCase().includes("seller"));

buyers.sort((a,b)=>buyerPriority(a.status)-buyerPriority(b.status));
sellers.sort((a,b)=>sellerPriority(a.status)-sellerPriority(b.status));

let exportHTML="";
let importHTML="";

buyers.forEach(p=>{

const statusClass=getStatusClass(p.status);

exportHTML+=`

<tr class="row-${statusClass}">
<td>${p.status}</td>
<td class="company">${p.company}</td>
<td>${p.contact}</td>
<td>${p.country}</td>
<td>${p.phone}</td>
<td class="brands">${p.brands}</td>
<td>${formatDate(p.statusDate)}</td>
</tr>

`;

});

sellers.forEach(p=>{

const statusClass=getStatusClass(p.status);

importHTML+=`

<tr class="row-${statusClass}">
<td>${p.status}</td>
<td class="company">${p.company}</td>
<td>${p.contact}</td>
<td>${p.country}</td>
<td>${p.phone}</td>
<td class="brands">${p.brands}</td>
<td>${formatDate(p.statusDate)}</td>
</tr>

`;

});

document.getElementById("exportBody").innerHTML=exportHTML;
document.getElementById("importBody").innerHTML=importHTML;

document.getElementById("exportCount").innerText=buyers.length;

document.getElementById("contractCount").innerText =
rows.filter(p=>getStatusClass(p.status)=="contract").length;

document.getElementById("discussionCount").innerText =
rows.filter(p=>getStatusClass(p.status)=="discussion").length;

document.getElementById("inactiveCount").innerText =
rows.filter(p=>getStatusClass(p.status)=="inactive").length;

}

load();

setInterval(load,15000);

function copyTable(type){

let table=document.getElementById(type+"Table");

let title=document.createElement("div");

title.style.fontSize="20px";
title.style.fontWeight="700";
title.style.marginBottom="10px";
title.style.color="black";

title.innerText = type==="export"
? "Export Partners"
: "Import Partners";

table.parentNode.insertBefore(title,table);

const range=document.createRange();
range.setStartBefore(title);
range.setEndAfter(table);

const selection=window.getSelection();
selection.removeAllRanges();
selection.addRange(range);

document.execCommand("copy");

selection.removeAllRanges();

title.remove();

}

</script>

</body>
</html>
